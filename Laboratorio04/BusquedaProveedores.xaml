<Window x:Class="Laboratorio04.BusquedaProveedores"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboratorio04"
        mc:Ignorable="d"
Title="Proveedores - Neptuno" Height="450" Width="700" Background="#F5F5F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Búsqueda de Proveedores" FontSize="20" FontWeight="Light" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,15" BorderBrush="#EEE" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Contacto:" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="txtContacto" Width="150" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Ciudad:" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="txtCiudad" Width="150" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Content="BUSCAR" Click="BtnBuscar_Click" Width="100" Height="30" VerticalAlignment="Bottom" 
                        Background="#007AFF" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgProveedores" Grid.Row="2" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Compañía" Binding="{Binding nombreCompañia}" Width="200"/>
                <DataGridTextColumn Header="Contacto" Binding="{Binding nombrecontacto}" Width="150"/>
                <DataGridTextColumn Header="Ciudad" Binding="{Binding ciudad}" Width="120"/>
                <DataGridTextColumn Header="País" Binding="{Binding pais}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
